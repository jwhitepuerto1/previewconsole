# Copy this to `.env` on the deploy host (next to docker-compose.yml) and
# fill in real values. NEVER commit the real .env file.

# Postgres connection strings — asyncpg driver, and if the password contains
# any URL-reserved character (#, @, %, etc.) it MUST be percent-encoded
# (e.g. "#" -> "%23") or the connection string silently truncates.
# Managed Postgres providers usually also require SSL — check whether yours
# needs "?ssl=require" appended.
PLATFORM_DATABASE_URL=postgresql+asyncpg://user:password@host:5432/ias_crm_platform
PREVIEW_DATABASE_URL_MERIDIAN=postgresql+asyncpg://user:password@host:5432/ias_crm_preview_meridian
PREVIEW_DATABASE_URL_CORNERSTONE=postgresql+asyncpg://user:password@host:5432/ias_crm_preview_cornerstone
PREVIEW_DATABASE_URL_ELEVATION=postgresql+asyncpg://user:password@host:5432/ias_crm_preview_elevation

# Generate a fresh one for production — never reuse the local dev secret.
# python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=replace-me

# Mautic (preview-signup lead push — see app/integrations/mautic.py).
# MAUTIC_REDIRECT_URI must exactly match the Redirect URI saved on the
# Mautic API credential, and must point at this deployment's own public
# origin + /oauth/callback (proxied to the backend by ui/next.config.ts).
# After deploying, authorize once by visiting authorize_url() in a browser
# — no script/CLI step needed, the /oauth/callback route completes the
# exchange server-side and stores the refresh token in the platform DB.
MAUTIC_BASE_URL=https://your-mautic-instance.example.com
MAUTIC_CLIENT_ID=replace-me
MAUTIC_CLIENT_SECRET=replace-me
MAUTIC_REDIRECT_URI=https://your-crm-domain.example.com/oauth/callback
MAUTIC_SEGMENT_ID=replace-me

# Smartlead (campaign email sequences — see app/services/smartlead.py).
# SMARTLEAD_WEBHOOK_SECRET guards POST /api/email-events/sync/{client_id} —
# set it here, then set the same value as the shared secret when registering
# that URL as Smartlead's webhook for a campaign.
SMARTLEAD_API_KEY=replace-me
SMARTLEAD_WEBHOOK_SECRET=replace-me

# SuiteCRM (investor-relationship record keeping — app/services/suitecrm.py).
# SUITECRM_API_KEY is assumed to already be a valid bearer/personal access
# token — see that module's docstring if your instance needs an OAuth2
# exchange first.
SUITECRM_URL=https://your-suitecrm-instance.example.com
SUITECRM_API_KEY=replace-me

# North Capital (KYC/accreditation/subscription docs — app/services/north_capital.py).
# NORTH_CAPITAL_WEBHOOK_SECRET guards POST
# /api/onboarding/webhooks/north-capital/{client_id} the same way
# SMARTLEAD_WEBHOOK_SECRET guards its own webhook.
NORTH_CAPITAL_BASE_URL=https://your-north-capital-instance.example.com
NORTH_CAPITAL_API_KEY=replace-me
NORTH_CAPITAL_ENVIRONMENT=sandbox
NORTH_CAPITAL_WEBHOOK_SECRET=replace-me
